# === Variables del parte JusCABA (EJE) ===
# El parte EJE COMPARTE el .env con el parte PJN (SMTP, FERIADOS, MODO_VENTANA, DIAS,
# ENVIAR_SIN_NOVEDADES). Aca van solo las variables propias de EJE. Copiar estas
# lineas al final del .env existente.

# === MODO AUTENTICADO (recomendado) - Portal del Litigante ===
# Con credenciales, el bot baja TU CARTERA EXACTA (Mis Causas del portal), incluidas
# las causas RESERVADAS (penal/PCyF y sensibles) que la consulta publica no muestra.
# No hay homonimos que depurar. Login via Keycloak (grant password, cliente iol-ui).
# EJE_USUARIO = tu CUIT (con o sin guiones; el bot los saca).
# EJE_CLAVE   = tu clave del EJE. OJO: este archivo queda en tu disco; protege el .env.
EJE_USUARIO=
EJE_CLAVE=

# Config Keycloak (ya fijada; pisar solo si el server cambia).
# EJE_AUTH_URL=https://eje.juscaba.gob.ar/auth
# EJE_REALM=IOL-CABA
# EJE_CLIENT_ID=iol-ui

# === MODO PUBLICO (solo si NO cargas credenciales arriba) ===
# Descubrimiento hibrido por nombre. Solo ve causas NO reservadas. Separar con ; o |.
# El bot agrega lo que encuentre a cartera-eje.xlsx; despues depuras con "Vigilar".
# Ej: EJE_CRITERIOS=Perez Juan;Estudio XYZ
EJE_CRITERIOS=

# Descubrir en cada corrida (true) o solo vigilar lo que ya este en la cartera (false).
EJE_DESCUBRIR=true
# Resultados por pagina al descubrir.
EJE_DESCUBRIR_SIZE=30

# Destinatario del parte CABA. Si se omite, usa MAIL_TO (el mismo del parte PJN).
# MAIL_TO_EJE=destinatario@gmail.com

# Tope de causas a consultar por corrida y pausa entre requests (ser amable con la API).
EJE_MAX_EXP=500
EJE_PAUSA_MS=250
EJE_TIMEOUT_MS=25000

# === PDF de las novedades ===
# Adjuntar al mail el PDF de cada actuacion nueva (true/false).
EJE_ADJUNTAR_PDFS=true
# Guardar tambien una copia local, en una carpeta nueva por dia (true/false).
EJE_GUARDAR_PDFS_LOCAL=true
# Carpeta base de las copias por dia. Default: <repo>/pdfs-eje.
# EJE_CARPETA_PDFS=C:\Users\TuUsuario\Documents\Novedades EJE
# Tope de PDF adjuntos por correo (Gmail corta en ~25 MB).
EJE_MAX_PDFS=20

# === Caducidad de instancia CAyT (art. 216 Ley 189) ===
# Plazo base en meses (default 6), dias de intimacion (default 30) y a cuantos dias del
# vencimiento empieza a avisar (default 45). Se pueden pisar por causa en la cartera.
# EJE_CADUCIDAD_MESES=6
# EJE_CADUCIDAD_INTIMACION_DIAS=30
# EJE_CADUCIDAD_AVISO_DIAS=45

# === API (opcional) ===
# La base ya esta fijada en el cliente. Solo pisar si el server cambia de URL.
# EJE_API_BASE=https://eje.juscaba.gob.ar/iol-api/api/public
# EJE_TIMEOUT_MS=25000
