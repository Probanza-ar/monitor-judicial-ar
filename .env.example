# === Portal PJN ===
# Solo se usan si la sesion persistente del navegador caduco y hay que re-loguear.
PJN_USER=
PJN_PASS=

# === Gmail SMTP ===
# IMPORTANTE: no es tu clave normal de Gmail. Es una CONTRASENA DE APLICACION.
# Requiere tener activada la verificacion en 2 pasos en tu cuenta de Google.
# Se genera en: Cuenta de Google > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicacion.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tucasilla@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
MAIL_FROM=tucasilla@gmail.com
MAIL_TO=destinatario@gmail.com

# === Alerta de falla critica ===
# Si el script falla (portal caido, token, SMTP, red), manda un mail de aviso.
ALERTA_FALLA=true
# Destinatario de la alerta de falla. Si se deja vacio, usa MAIL_TO.
# Conviene un canal que mires seguro (ej. tu casilla personal o un SMS-a-mail).
MAIL_TO_ALERTA=
# Fallback local: si NO se pudo mandar el mail de falla (red/IP/SMTP caidos), el
# script escribe ALERTA_CRITICA.txt en esta carpeta y hace un beep de consola.
# Default: la carpeta del repo. Sugerencia: el Escritorio para que salte a la vista.
# ALERTA_LOCAL_DIR=C:\Users\TuUsuario\Desktop

# === Ventana temporal ===
# habil = calcula el corte hasta el ultimo dia habil (toma el finde y feriados).
# fijo  = usa DIAS como ventana fija de N x 24 hs.
MODO_VENTANA=habil
# Ventana hacia atras en dias (solo se usa si MODO_VENTANA=fijo).
DIAS=1
# Feriados judiciales / no laborables a excluir del calculo (modo habil).
# DEJAR VACIO: el calendario ya esta cargado en feriados.json (ver
# feriados-2026-fuentes.md). Esta variable es solo para agregar fechas sueltas
# extra sin tocar el JSON. Formato YYYY-MM-DD separados por coma. El script suma
# ambas fuentes. Actualizar feriados.json cada anio.
FERIADOS=

# === Validacion de descarga ===
# Tamano minimo en bytes para considerar valido un PDF (descarta 0 KB / truncos).
PDF_MIN_BYTES=1000

# === Parametros generales ===
# Paginas del feed a revisar (20 eventos c/u).
PAGINAS=5
# Enviar el correo aunque no haya novedades (true) o solo si hay algo (false).
ENVIAR_SIN_NOVEDADES=true
# Adjuntar el PDF de cada novedad al mail (true/false).
ADJUNTAR_PDFS=true
# Tope de PDFs por correo (Gmail corta en ~25 MB).
MAX_PDFS=25
# Guardar tambien los PDF en disco, en una carpeta nueva por dia (true/false).
GUARDAR_PDFS_LOCAL=true
# Carpeta base donde se crean las subcarpetas por dia. Default: <repo>/pdfs.
# CARPETA_PDFS=C:\Users\TuUsuario\Documents\Novedades PJN

# === Write-back al Excel de gestion (opcional) ===
# Si EXCEL_PATH esta seteada, tras enviar el parte el script marca en el Excel las
# causas con novedad. Requiere: npm i exceljs
# Por SEGURIDAD escribe sobre una COPIA (EXCEL_OUT); no toca tu maestro salvo que
# pongas EXCEL_INPLACE=true de forma explicita.
# EXCEL_PATH=C:\ruta\a\tu\GestionEstudioJuridico.xlsx
# EXCEL_OUT=  (default: <EXCEL_PATH>.actualizado.xlsx)
# EXCEL_INPLACE=false
# EXCEL_HOJA=  (opcional: forzar el nombre de la hoja de causas, ej. CAUSAS)

# === Navegador ===
# En la PRIMERA corrida conviene HEADLESS=false para loguearte a mano una vez
# y que Chromium guarde la sesion. Despues HEADLESS=true para el modo automatico.
HEADLESS=true
# PROFILE_DIR=  (opcional; default: <repo>/.pjn-profile)
# En VPS ARM (ej. Oracle Ampere) puppeteer no trae Chromium para arm64: instalar
# chromium del sistema y apuntarlo aca (ver DESPLIEGUE-VPS.md).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
