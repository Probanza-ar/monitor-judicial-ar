# === Portal PJN ===
# Solo se usan si la sesion persistente del navegador caduco y hay que re-loguear.
PJN_USER=
PJN_PASS=

# === Gmail SMTP ===
# IMPORTANTE: no es tu clave normal de Gmail. Es una CONTRASENA DE APLICACION.
# Requiere tener activada la verificacion en 2 pasos en tu cuenta de Google.
# Se genera en: Cuenta de Google > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicacion.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tucasilla@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
MAIL_FROM=tucasilla@gmail.com
MAIL_TO=destinatario@gmail.com

# === Parametros ===
# Ventana hacia atras en dias (1 = ultimas 24 hs).
DIAS=1
# Paginas del feed a revisar (20 eventos c/u).
PAGINAS=5
# Enviar el correo aunque no haya novedades (true) o solo si hay algo (false).
ENVIAR_SIN_NOVEDADES=true
# Adjuntar el PDF de cada novedad al mail (true/false).
ADJUNTAR_PDFS=true
# Tope de PDFs por correo (evita mails gigantes; Gmail corta en ~25 MB).
MAX_PDFS=25
# Guardar tambien los PDF en disco, en una carpeta nueva por dia (true/false).
GUARDAR_PDFS_LOCAL=true
# Carpeta base donde se crean las subcarpetas por dia. Default: scripts/pdfs.
# CARPETA_PDFS=C:\Users\TuUsuario\Documents\Novedades PJN

# === Navegador ===
# En la PRIMERA corrida conviene HEADLESS=false para loguearte a mano una vez
# y que Chromium guarde la sesion. Despues poné HEADLESS=true para el modo automatico.
HEADLESS=true
# PROFILE_DIR=  (opcional; default: scripts/.pjn-profile)
