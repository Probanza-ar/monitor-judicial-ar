# === Frente MEV / SCBA (Provincia de Buenos Aires) ===
# Pegar estas variables al .env existente (comparte SMTP, feriados y ventana con
# los partes PJN y EJE). Sin MEV_USUARIO/MEV_CLAVE el parte MEV no corre: la MEV
# no tiene consulta anonima.

# Credenciales de la Mesa de Entradas Virtual (mev.scba.gov.ar).
MEV_USUARIO=
MEV_CLAVE=
# "Creado en" del login. aa = TODOS los Deptos (default). Si tu usuario es viejo y
# el login falla, proba con el codigo del depto donde lo registraste (MO=Moron,
# SI=San Isidro, LP=La Plata, etc.; sufijo F = variante Familia).
MEV_DEPTO_REGISTRADO=aa

# Jurisdicciones a recorrer: departamento judicial + fuero, separadas por ";".
# Formato: "NombreDepto[:penal][:familia]". El nombre matchea contra el listado
# del propio portal (no hace falta el codigo interno).
# Ej: la causa penal autorizada en Moron + la sucesion en San Isidro:
MEV_JURISDICCIONES=Moron:penal;San Isidro

# Destinatario del parte MEV. Si no se define, cae en MAIL_TO.
MAIL_TO_MEV=

# Pausa entre requests (ms). La MEV es un ASP viejo: no bajar de 300-400.
MEV_PAUSA_MS=400
# Timeout HTTP (ms).
MEV_TIMEOUT_MS=30000

# Aviso de caducidad: dias de anticipacion para la fase EN CURSO (default 45)
# y dias del perentorio de intimacion art. 315 (default 5 habiles; no tocar
# salvo reforma legal).
# MEV_CADUCIDAD_AVISO_DIAS=45
# MEV_CADUCIDAD_INTIMACION_DIAS=5

# Ruta de la cartera (default: <repo>/cartera-mev.xlsx).
# CARTERA_MEV_XLSX=
